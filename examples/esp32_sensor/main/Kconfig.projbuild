menu "Micronet ESP32 Demo"

config MICRONET_DEMO_NODE_SLOT
    int "Node slot"
    range 1 3
    default 1
    help
        Select which physical board this firmware image represents.

config MICRONET_DEMO_WIFI_SSID
    string "Wi-Fi SSID"
    default "YOUR_WIFI_SSID"

config MICRONET_DEMO_WIFI_PASSWORD
    string "Wi-Fi password"
    default "YOUR_WIFI_PASSWORD"

config MICRONET_DEMO_UDP_PORT
    int "UDP port"
    range 1024 65535
    default 33333

config MICRONET_DEMO_TELEMETRY_PERIOD_MS
    int "Telemetry period in milliseconds"
    range 250 60000
    default 2000

config MICRONET_DEMO_RETRY_COUNT
    int "Transport retry count"
    range 0 10
    default 2

config MICRONET_DEMO_NODE1_IP
    string "Node 1 IPv4 address"
    default "192.168.1.101"

config MICRONET_DEMO_NODE2_IP
    string "Node 2 IPv4 address"
    default "192.168.1.102"

config MICRONET_DEMO_NODE3_IP
    string "Node 3 IPv4 address"
    default "192.168.1.103"

endmenu
