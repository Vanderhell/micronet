<Window x:Class="MicronetViz.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MicronetViz"
        mc:Ignorable="d"
        Title="Micronet Viz"
        Width="1460"
        Height="900"
        MinWidth="1180"
        MinHeight="760"
        WindowStyle="None"
        Background="#07111D"
        WindowStartupLocation="CenterScreen">
    <Window.InputBindings>
        <KeyBinding Key="P" Modifiers="Control" Command="{Binding PublishCommand}" />
        <KeyBinding Key="U" Modifiers="Control" Command="{Binding UpdateCommand}" />
        <KeyBinding Key="Enter" Modifiers="Control" Command="{Binding SendCustomCommand}" />
        <KeyBinding Key="B" Modifiers="Control" Command="{Binding BroadcastCommand}" />
        <KeyBinding Key="G" Modifiers="Control" Command="{Binding GroupCreateCommand}" />
        <KeyBinding Key="J" Modifiers="Control" Command="{Binding GroupJoinCommand}" />
        <KeyBinding Key="L" Modifiers="Control" Command="{Binding GroupLeaveCommand}" />
    </Window.InputBindings>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <local:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />

        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Background" Value="#101C2B" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#F3F7FB" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <Style x:Key="NodeBadgeStyle" TargetType="Border">
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="#16273A" />
        </Style>

        <Style x:Key="CardMetricStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Background" Value="#152335" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Margin" Value="0,0,14,0" />
        </Style>

        <Style x:Key="InfoPanelBorderStyle" TargetType="Border" BasedOn="{StaticResource PanelBorderStyle}">
            <Setter Property="Background" Value="#0B1623" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>

        <Style x:Key="InfoSectionTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource SectionTitleStyle}">
            <Setter Property="Foreground" Value="#B7C8D9" />
            <Setter Property="FontSize" Value="16" />
        </Style>

        <Style x:Key="ControlPanelBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#F7E4C9" Offset="0" />
                        <GradientStop Color="#E8C28D" Offset="1" />
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ControlTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#2C1700" />
        </Style>

        <Style x:Key="ControlLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#5A3606" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style x:Key="ControlTextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Background" Value="#FFF9F0" />
            <Setter Property="Foreground" Value="#2A1800" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style x:Key="ControlComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Background" Value="#FFF9F0" />
            <Setter Property="Foreground" Value="#2A1800" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="1"
                CornerRadius="24"
                Padding="22"
                Margin="0,0,0,18"
                Background="#0D1826"
                BorderBrush="Transparent"
                BorderThickness="0"
                MouseLeftButtonDown="HeaderBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="34"
                               FontWeight="Bold"
                               Foreground="#F8FBFF"
                               Text="Micronet" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Top">
                    <Border Style="{StaticResource NodeBadgeStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10" Height="10" Fill="#63D471" VerticalAlignment="Center" />
                            <TextBlock Margin="8,0,0,0" Foreground="#DDF5E1" Text="{Binding StatusText}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource NodeBadgeStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Foreground="#9EB3C8" Text="Tick" />
                            <TextBlock Margin="8,0,0,0" Foreground="#F8FBFF" Text="{Binding TickCount}" />
                        </StackPanel>
                    </Border>
                    <Button Margin="8,0,0,0"
                            Padding="12,7"
                            Background="#3E5B77"
                            Foreground="White"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            Content="_"
                            Click="MinimizeButton_Click" />
                    <Button Margin="8,0,0,0"
                            Padding="12,7"
                            Background="#4E6B87"
                            Foreground="White"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            Content="[]"
                            Click="MaximizeButton_Click" />
                    <Button Margin="8,0,0,0"
                            Padding="14,7"
                            Background="#C55353"
                            Foreground="White"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            Content="Exit"
                            Click="ExitButton_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="0" Style="{StaticResource InfoPanelBorderStyle}" Padding="16,12" Margin="0,0,0,12">
            <ItemsControl ItemsSource="{Binding SummaryCards}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="6" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type local:SummaryCardViewModel}">
                        <Border Margin="0,0,10,0" Style="{StaticResource CardMetricStyle}">
                            <StackPanel>
                                <TextBlock Foreground="#8FA8BF" Text="{Binding Label}" />
                                <TextBlock Margin="0,8,0,0"
                                           FontSize="28"
                                           FontWeight="Bold"
                                           Foreground="#F5FAFF"
                                           Text="{Binding Value}" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="#69C3FF"
                                           Text="{Binding Hint}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.1*" />
                <ColumnDefinition Width="1.3*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,16,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="0" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource InfoPanelBorderStyle}" Visibility="Collapsed">
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding SummaryCards}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type local:SummaryCardViewModel}">
                                    <Border Width="180" Style="{StaticResource CardMetricStyle}">
                                        <StackPanel>
                                            <TextBlock Foreground="#8FA8BF" Text="{Binding Label}" />
                                            <TextBlock Margin="0,10,0,0"
                                                       FontSize="30"
                                                       FontWeight="Bold"
                                                       Foreground="#F5FAFF"
                                                       Text="{Binding Value}" />
                                            <TextBlock Margin="0,8,0,0"
                                                       Foreground="#69C3FF"
                                                       Text="{Binding Hint}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.35*" />
                        <ColumnDefinition Width="0.95*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}" Margin="0,0,16,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" Margin="0,0,0,12">
                                <TextBlock Style="{StaticResource SectionTitleStyle}" DockPanel.Dock="Left" Text="Mesh Topológia" />
                            </DockPanel>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Nodes}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type local:NodeViewModel}">
                                            <Border Margin="0,0,0,14"
                                                    Padding="16"
                                                    CornerRadius="18"
                                                    BorderBrush="Transparent"
                                                    BorderThickness="0"
                                                    Background="#122133">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <Border Width="54"
                                                            Height="54"
                                                            CornerRadius="27"
                                                            Background="{Binding AccentBrush}"
                                                            VerticalAlignment="Top">
                                                        <TextBlock HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   FontSize="18"
                                                                   FontWeight="Bold"
                                                                   Foreground="#07111D"
                                                                   Text="{Binding ShortLabel}" />
                                                    </Border>

                                                    <StackPanel Grid.Column="1" Margin="14,0,12,0">
                                                        <TextBlock FontSize="17"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#F4F8FD"
                                                                   Text="{Binding Name}" />
                                                        <TextBlock Margin="0,4,0,0"
                                                                   Foreground="#8FA8BF"
                                                                   Text="{Binding NodeId}" />
                                                        <TextBlock Margin="0,8,0,0"
                                                                   Foreground="#D2E1EF"
                                                                   Text="{Binding Role}" />
                                                        <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding Peers}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <WrapPanel />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Margin="0,0,8,8"
                                                                            Padding="8,4"
                                                                            CornerRadius="999"
                                                                            Background="#193049"
                                                                            BorderBrush="Transparent"
                                                                            BorderThickness="0">
                                                                        <TextBlock Foreground="#D8E9F8" Text="{Binding}" />
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                                        <Border Padding="10,5"
                                                                CornerRadius="999"
                                                                Background="{Binding StatusBrush}">
                                                            <TextBlock FontWeight="SemiBold"
                                                                       Foreground="#081019"
                                                                       Text="{Binding OnlineText}" />
                                                        </Border>
                                                        <TextBlock Margin="0,14,0,0"
                                                                   HorizontalAlignment="Right"
                                                                   Foreground="#69C3FF"
                                                                   Text="{Binding MessageRateText}" />
                                                        <TextBlock Margin="0,6,0,0"
                                                                   HorizontalAlignment="Right"
                                                                   Foreground="#8FA8BF"
                                                                   Text="{Binding LastSeenText}" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource PanelBorderStyle}" Margin="0,0,0,16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Tok Správ" />

                            <ListBox Grid.Row="1"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="#E9F2FA"
                                     ItemsSource="{Binding Messages}"
                                     SelectedItem="{Binding SelectedMessage}">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Margin" Value="0,0,0,12" />
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type local:MessageViewModel}">
                                        <Border Padding="14"
                                                CornerRadius="16"
                                                Background="#142537"
                                                BorderBrush="Transparent"
                                                BorderThickness="0">
                                            <StackPanel>
                                                <DockPanel>
                                                    <TextBlock DockPanel.Dock="Left"
                                                               FontWeight="SemiBold"
                                                               Foreground="#F6FBFF"
                                                               Text="{Binding Route}" />
                                                    <TextBlock HorizontalAlignment="Right"
                                                               Foreground="#7ECDFD"
                                                               Text="{Binding TimestampText}" />
                                                </DockPanel>
                                                <TextBlock Margin="0,8,0,0"
                                                           Foreground="#C6D7E7"
                                                           Text="{Binding Kind}" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Foreground="#8FA8BF"
                                                           Text="{Binding Preview}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1.15*" />
                    <RowDefinition Height="0.95*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource PanelBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="MicroDB Stav" />

                        <DataGrid Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  HeadersVisibility="Column"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  Background="#0F1B29"
                                  RowBackground="#112131"
                                  AlternatingRowBackground="#15283C"
                                  BorderBrush="Transparent"
                                  BorderThickness="0"
                                  Foreground="#E9F3FB"
                                  ItemsSource="{Binding DatabaseEntries}">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#16283B" />
                                    <Setter Property="Foreground" Value="#A9C0D7" />
                                    <Setter Property="BorderBrush" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0" />
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Node" Binding="{Binding NodeName}" Width="1.15*" />
                                <DataGridTextColumn Header="Key" Binding="{Binding Key}" Width="1.15*" />
                                <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="0.9*" />
                                <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="1.35*" />
                                <DataGridTextColumn Header="Updated" Binding="{Binding UpdatedAgo}" Width="0.85*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource InfoPanelBorderStyle}" Padding="18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Style="{StaticResource InfoSectionTitleStyle}" Text="Vybraný Uzol (Informačne)" />
                                <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="#F3F8FD" Text="{Binding SelectedNode.Name}" />
                                <TextBlock Margin="0,4,0,0" Foreground="#8FA8BF" Text="{Binding SelectedNode.NodeId}" />
                                <TextBlock Margin="0,10,0,0" Foreground="#D0DFEC" Text="{Binding SelectedNode.Role}" />
                            </StackPanel>

                            <UniformGrid Grid.Column="1" Columns="2">
                                <StackPanel Margin="10,0,0,0">
                                    <TextBlock Foreground="#8FA8BF" Text="Packets Sent" />
                                    <TextBlock FontSize="24" FontWeight="Bold" Foreground="#F6FBFF" Text="{Binding SelectedNode.PacketsSent}" />
                                </StackPanel>
                                <StackPanel Margin="10,0,0,0">
                                    <TextBlock Foreground="#8FA8BF" Text="Packets Recv" />
                                    <TextBlock FontSize="24" FontWeight="Bold" Foreground="#F6FBFF" Text="{Binding SelectedNode.PacketsReceived}" />
                                </StackPanel>
                                <StackPanel Margin="10,16,0,0">
                                    <TextBlock Foreground="#8FA8BF" Text="Health" />
                                    <TextBlock FontSize="24" FontWeight="Bold" Foreground="#73E2A7" Text="{Binding SelectedNode.HealthScore}" />
                                </StackPanel>
                                <StackPanel Margin="10,16,0,0">
                                    <TextBlock Foreground="#8FA8BF" Text="Free Heap" />
                                    <TextBlock FontSize="24" FontWeight="Bold" Foreground="#7ECDFD" Text="{Binding SelectedNode.FreeHeapText}" />
                                </StackPanel>
                            </UniformGrid>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource InfoPanelBorderStyle}" Margin="0,16,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Style="{StaticResource InfoSectionTitleStyle}" Text="Detail Správy (Informačne)" />
                            <Border Grid.Row="1"
                                    Padding="14"
                                    CornerRadius="14"
                                    Background="#112131"
                                    BorderBrush="Transparent"
                                    BorderThickness="0"
                                    Visibility="{Binding HasSelectedMessage, Converter={StaticResource BoolToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="#F4F8FD" Text="{Binding SelectedMessage.Route}" />
                                    <TextBlock Margin="0,8,0,0" Foreground="#7ECDFD" Text="{Binding SelectedMessage.Kind}" />
                                    <TextBlock Margin="0,8,0,0" Foreground="#8FA8BF" Text="{Binding SelectedMessage.TimestampText}" />
                                    <TextBlock Margin="0,12,0,0"
                                               TextWrapping="Wrap"
                                               Foreground="#D5E3F0"
                                               Text="{Binding SelectedMessage.Payload}" />
                                </StackPanel>
                            </Border>
                            <TextBlock Grid.Row="1"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="#6E859B"
                                       FontStyle="Italic"
                                       Text="Vyber správu z ľavého panelu."
                                       Visibility="{Binding HasSelectedMessage, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                            <Border Grid.Row="2"
                                    Margin="0,14,0,0"
                                    Style="{StaticResource ControlPanelBorderStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.2*" />
                                        <ColumnDefinition Width="1.4*" />
                                        <ColumnDefinition Width="0.8*" />
                                        <ColumnDefinition Width="1.45*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Row="0" Grid.ColumnSpan="4"
                                               Style="{StaticResource ControlTitleStyle}"
                                               Text="Bridge Ovládanie" />
                                    <Border Grid.Row="0"
                                            Grid.ColumnSpan="4"
                                            Margin="0,34,0,10"
                                            Padding="10,8"
                                            CornerRadius="10"
                                            Background="#FDF2E3"
                                            BorderBrush="Transparent"
                                            BorderThickness="0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock VerticalAlignment="Center"
                                                       FontWeight="SemiBold"
                                                       Foreground="#5A3606"
                                                       Text="WPF Node ID:" />
                                            <TextBox Grid.Column="1"
                                                     Margin="8,0,12,0"
                                                     Padding="6,4"
                                                     IsReadOnly="True"
                                                     Background="#FFF9F0"
                                                     Foreground="#2A1800"
                                                     BorderBrush="#CF9040"
                                                     Text="{Binding AppNodeIdHex, Mode=OneWay}" />
                                            <TextBlock Grid.Column="2"
                                                       VerticalAlignment="Center"
                                                       FontWeight="SemiBold"
                                                       Foreground="#5A3606"
                                                       Text="UDP Port:" />
                                            <TextBlock Grid.Column="3"
                                                       Margin="8,0,0,0"
                                                       VerticalAlignment="Center"
                                                       FontWeight="Bold"
                                                       Foreground="#2A1800"
                                                       Text="{Binding AppListenPort}" />
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,8">
                                        <TextBlock Style="{StaticResource ControlLabelStyle}" Text="Publish Key" />
                                        <TextBox Style="{StaticResource ControlTextBoxStyle}"
                                                 Text="{Binding PublishKey, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,8,8">
                                        <TextBlock Style="{StaticResource ControlLabelStyle}" Text="Publish Value" />
                                        <TextBox Style="{StaticResource ControlTextBoxStyle}"
                                                 Text="{Binding PublishValue, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <Button Grid.Row="1" Grid.Column="2"
                                            Margin="0,19,8,8"
                                            Padding="14,10"
                                            Background="#2B6CC2"
                                            Foreground="#F8FBFF"
                                            BorderBrush="#2458A0"
                                            FontWeight="SemiBold"
                                            Content="Publish"
                                            ToolTip="Ctrl+P"
                                            Command="{Binding PublishCommand}" />
                                    <Button Grid.Row="1" Grid.Column="3"
                                            Margin="0,19,0,8"
                                            Padding="14,10"
                                            Background="#2565A8"
                                            Foreground="#F8FBFF"
                                            BorderBrush="#1F548A"
                                            FontWeight="SemiBold"
                                            Content="Update"
                                            ToolTip="Ctrl+U"
                                            Command="{Binding UpdateCommand}" />

                                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,0">
                                        <TextBlock Style="{StaticResource ControlLabelStyle}" Text="Target Node (zoznam)" />
                                        <ComboBox Style="{StaticResource ControlComboBoxStyle}"
                                                  ItemsSource="{Binding SendTargets}"
                                                  SelectedItem="{Binding SelectedTargetNode}"
                                                  DisplayMemberPath="Name" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,8,0">
                                        <TextBlock Style="{StaticResource ControlLabelStyle}" Text="Target Node ID (manuálne)" />
                                        <TextBox x:Name="ManualTargetNodeIdTextBox"
                                                 Style="{StaticResource ControlTextBoxStyle}"
                                                 BorderBrush="{Binding TargetBorderBrush}"
                                                 BorderThickness="2"
                                                 PreviewTextInput="HexNodePreviewTextInput"
                                                 DataObject.Pasting="HexNodePasting"
                                                 TextChanged="ManualTargetNodeIdTextChanged"
                                                 ToolTip="Target Node ID: 32 bytes hex (64 znakov). Povolený formát: aa11... alebo aa:11:..."
                                                 Text="{Binding ManualTargetNodeId, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,8,0">
                                        <TextBlock Style="{StaticResource ControlLabelStyle}" Text="Group Hash" />
                                        <TextBox x:Name="GroupHashTextBox"
                                                 Style="{StaticResource ControlTextBoxStyle}"
                                                 BorderBrush="{Binding GroupHashBorderBrush}"
                                                 BorderThickness="2"
                                                 PreviewTextInput="HexNodePreviewTextInput"
                                                 DataObject.Pasting="HexNodePasting"
                                                 TextChanged="GroupHashTextChanged"
                                                 ToolTip="Group Hash: 16 bytes hex (32 znakov). Môžeš písať aj s : alebo -, normalizuje sa."
                                                 Text="{Binding GroupHash, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <Button Grid.Row="2" Grid.Column="3"
                                            Padding="14,10"
                                            Background="#7E4A19"
                                            Foreground="#FFF4E7"
                                            BorderBrush="#663C13"
                                            FontWeight="SemiBold"
                                            Content="Leave Group"
                                            ToolTip="Ctrl+L"
                                            Command="{Binding GroupLeaveCommand}" />

                                    <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,8,8,0">
                                        <TextBlock Style="{StaticResource ControlLabelStyle}" Text="Custom Payload" />
                                        <TextBox Style="{StaticResource ControlTextBoxStyle}"
                                                 Text="{Binding CustomPayload, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="3" Grid.Column="1" Margin="0,8,8,0">
                                        <TextBlock Style="{StaticResource ControlLabelStyle}" Text="Group Key" />
                                        <TextBox x:Name="GroupKeyTextBox"
                                                 Style="{StaticResource ControlTextBoxStyle}"
                                                 BorderBrush="{Binding GroupKeyBorderBrush}"
                                                 BorderThickness="2"
                                                 PreviewTextInput="HexNodePreviewTextInput"
                                                 DataObject.Pasting="HexNodePasting"
                                                 TextChanged="GroupKeyTextChanged"
                                                 ToolTip="Group Key: 16 bytes hex (32 znakov). Môžeš písať aj s : alebo -, normalizuje sa."
                                                 Text="{Binding GroupKey, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="3" Grid.Column="2" Margin="0,8,8,0">
                                        <TextBlock Style="{StaticResource ControlLabelStyle}" Text="Msg Type" />
                                        <TextBox Style="{StaticResource ControlTextBoxStyle}"
                                                 Text="{Binding CustomMsgType, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <WrapPanel Grid.Row="3" Grid.Column="3" Margin="0,8,0,0">
                                        <Button Margin="0,0,6,6"
                                                Padding="14,10"
                                                Background="#E07A2E"
                                                Foreground="#231001"
                                                BorderBrush="#BE621E"
                                                FontWeight="SemiBold"
                                                Content="Send Custom"
                                                ToolTip="Ctrl+Enter"
                                                Command="{Binding SendCustomCommand}" />
                                        <Button Margin="0,0,6,6"
                                                Padding="14,10"
                                                Background="#A7682D"
                                                Foreground="#FFF4E7"
                                                BorderBrush="#8B5522"
                                                FontWeight="SemiBold"
                                                Content="Broadcast"
                                                ToolTip="Ctrl+B"
                                                Command="{Binding BroadcastCommand}" />
                                        <Button Margin="0,0,6,6"
                                                Padding="14,10"
                                                Background="#3C8B44"
                                                Foreground="#EBFFED"
                                                BorderBrush="#2D6E34"
                                                FontWeight="SemiBold"
                                                Content="Create Group"
                                                ToolTip="Ctrl+G"
                                                Command="{Binding GroupCreateCommand}" />
                                        <Button Margin="0,0,0,6"
                                                Padding="14,10"
                                                Background="#2A6AA8"
                                                Foreground="#EEF7FF"
                                                BorderBrush="#215486"
                                                FontWeight="SemiBold"
                                                Content="Join Group"
                                                ToolTip="Ctrl+J"
                                                Command="{Binding GroupJoinCommand}" />
                                    </WrapPanel>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                                               Margin="0,8,8,0"
                                               Foreground="#6A4119"
                                               Text="{Binding TargetValidationHint}" />
                                    <TextBlock Grid.Row="4" Grid.Column="2"
                                               Margin="0,8,8,0"
                                               Foreground="#6A4119"
                                               Text="{Binding GroupHashValidationHint}" />
                                    <TextBlock Grid.Row="4" Grid.Column="3"
                                               Margin="0,8,0,0"
                                               Foreground="#6A4119"
                                               Text="{Binding GroupKeyValidationHint}" />
                                    <TextBlock Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="4"
                                               Margin="0,8,0,0"
                                               Foreground="#5A3606"
                                               FontWeight="SemiBold"
                                               Text="Arduino Quick Actions (msg type 32):" />
                                    <WrapPanel Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="3" Margin="0,8,0,0">
                                        <Button Margin="0,0,6,6"
                                                Padding="13,9"
                                                Background="#7D4B17"
                                                Foreground="#FFF4E7"
                                                BorderBrush="#663C13"
                                                Content="Ping"
                                                Command="{Binding ArduinoPingCommand}" />
                                        <Button Margin="0,0,6,6"
                                                Padding="13,9"
                                                Background="#2B6CC2"
                                                Foreground="#F8FBFF"
                                                BorderBrush="#2458A0"
                                                Content="LED Toggle"
                                                Command="{Binding ArduinoLedToggleCommand}" />
                                        <Button Margin="0,0,6,6"
                                                Padding="13,9"
                                                Background="#3C8B44"
                                                Foreground="#EBFFED"
                                                BorderBrush="#2D6E34"
                                                Content="Relay Toggle"
                                                Command="{Binding ArduinoRelayToggleCommand}" />
                                    </WrapPanel>

                                    <Border Grid.Row="6"
                                            Grid.ColumnSpan="4"
                                            Margin="0,12,0,0"
                                            Padding="10"
                                            CornerRadius="10"
                                            Background="#F6E3C8"
                                            BorderBrush="Transparent"
                                            BorderThickness="0">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.1*" />
                                                <ColumnDefinition Width="1.5*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Row="0" Grid.ColumnSpan="5"
                                                       Foreground="#4A2E09"
                                                       FontWeight="Bold"
                                                       Text="Register Device" />

                                            <TextBox Grid.Row="1" Grid.Column="0"
                                                     Margin="0,8,8,0"
                                                     Padding="8,6"
                                                     Background="#FFF9F0"
                                                     Foreground="#2A1800"
                                                     BorderBrush="Transparent"
                                                     BorderThickness="0"
                                                     Text="{Binding RegisterAliasInput, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBox Grid.Row="1" Grid.Column="1"
                                                     Margin="0,8,8,0"
                                                     Padding="8,6"
                                                     Background="#FFF9F0"
                                                     Foreground="#2A1800"
                                                     BorderBrush="Transparent"
                                                     BorderThickness="0"
                                                     ToolTip="Node ID: 64 hex znakov (môže byť aj s : alebo -)"
                                                     Text="{Binding RegisterNodeIdInput, UpdateSourceTrigger=PropertyChanged}" />
                                            <Button Grid.Row="1" Grid.Column="2"
                                                    Margin="0,8,8,0"
                                                    Padding="12,8"
                                                    Background="#2D6E34"
                                                    Foreground="#EBFFED"
                                                    BorderBrush="#2D6E34"
                                                    Content="Register"
                                                    Command="{Binding RegisterDeviceCommand}" />
                                            <Button Grid.Row="1" Grid.Column="3"
                                                    Margin="0,8,8,0"
                                                    Padding="12,8"
                                                    Background="#2B6CC2"
                                                    Foreground="#F8FBFF"
                                                    BorderBrush="#2458A0"
                                                    Content="Use as Target"
                                                    Command="{Binding UseRegisteredDeviceCommand}" />
                                            <Button Grid.Row="1" Grid.Column="4"
                                                    Margin="0,8,0,0"
                                                    Padding="12,8"
                                                    Background="#8A3D3D"
                                                    Foreground="#FFEFEF"
                                                    BorderBrush="#8A3D3D"
                                                    Content="Remove"
                                                    Command="{Binding RemoveRegisteredDeviceCommand}" />

                                            <ListBox Grid.Row="2"
                                                     Grid.ColumnSpan="5"
                                                     Margin="0,10,0,0"
                                                     Background="#FFF9F0"
                                                     BorderBrush="Transparent"
                                                     BorderThickness="0"
                                                     Foreground="#2A1800"
                                                     ItemsSource="{Binding RegisteredDevices}"
                                                     SelectedItem="{Binding SelectedRegisteredDevice}">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type local:RegisteredDeviceViewModel}">
                                                        <DockPanel Margin="0,3,0,3">
                                                            <TextBlock DockPanel.Dock="Left"
                                                                       FontWeight="SemiBold"
                                                                       Text="{Binding Alias}" />
                                                            <TextBlock Margin="12,0,0,0"
                                                                       Foreground="#76512A"
                                                                       Text="{Binding NodeIdHex}" />
                                                        </DockPanel>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
